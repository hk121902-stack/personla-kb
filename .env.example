TELEGRAM_BOT_TOKEN=
# Optional: enables scheduled proactive digests for this Telegram chat.
# Use the same chat where links are saved; knowledge is scoped by chat id.
KB_TELEGRAM_CHAT_ID=
KB_DATABASE_PATH=./data/kb.sqlite3
KB_TIMEZONE=Asia/Kolkata
KB_DAILY_DIGEST_HOUR=9
KB_WEEKLY_DIGEST_DAY=sun
KB_WEEKLY_DIGEST_HOUR=10
# MVP runtime supports only "heuristic"; other providers are rejected.
KB_AI_PROVIDER=heuristic
